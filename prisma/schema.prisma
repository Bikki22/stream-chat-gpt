generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  clerkId   String   @unique
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String?
  lastName  String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
